# Spec Kit local state
.specify/extensions/*/local-config.yml

# Bridge audit log (append-only runtime state, regenerated per run)
.specify/bridge-events.jsonl
.specify/bridge-snapshots/

# Worktrees (created by the worktrees extension)
.worktrees/

# Skill evaluation workspaces (regenerable, large)
.claude/skills/*-workspace/

# Session scratch
.remember/now.md

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Node
node_modules/

# OS
.DS_Store
Thumbs.db

# Editors
.idea/
*.swp
